/// Schéma Prisma — RUHENNA
///
/// Rôle : définir le modèle de données (tables, champs, relations, contraintes)
/// utilisé par l’application (produits, services, rendez-vous, blog, galerie…).
///
/// Commandes utiles :
/// - `npx prisma generate` : génère Prisma Client + types
/// - `npx prisma migrate dev` : applique les migrations en local
/// - `npx prisma db seed` : exécute le seed
/// - `npx prisma studio` : interface de visualisation/édition de la base
/// - (optionnel) générer un ERD si un générateur est activé
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//generator erd {
// provider = "prisma-erd-generator"
//}


enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  category       String?
  images         String[]
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
}

model ProductCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Service {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  duration    Int
  price       Decimal   @db.Decimal(10, 2)
  image       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  appointments   Appointment[]
  availabilities ServiceAvailability[]

  @@index([slug])
}

model ServiceAvailability {
  id        String    @id @default(cuid())
  serviceId String
  dayOfWeek Int?
  startDate DateTime?
  endDate   DateTime?
  startTime String
  endTime   String
  createdAt DateTime  @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model Appointment {
  id          String            @id @default(cuid())
  serviceId   String
  date        DateTime
  startTime   String
  endTime     String
  status      AppointmentStatus @default(PENDING)
  notes       String?
  clientPhone String?
  clientName  String?
  clientEmail String?
  clientCity  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([date, startTime])
  @@index([date])
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id         String    @id @default(cuid())
  senderName String
  email      String?
  phone      String
  subject    String
  message    String
  read       Boolean   @default(false)
  archivedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
}

model HeroImage {
  id        String   @id @default(cuid())
  imageUrl  String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
